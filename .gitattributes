# Office documents are binary — never apply text/EOL conversion (would corrupt them).
*.pptx binary
*.docx binary
*.xlsx binary
*.pdf binary

# Unix shell launchers MUST stay LF — CRLF makes bash fail with '\r' errors on macOS/Linux.
*.sh text eol=lf
*.command text eol=lf
# Windows batch prefers CRLF.
*.bat text eol=crlf
