<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.3.5</version>
        <relativePath/>
    </parent>

    <groupId>com.uob</groupId>
    <artifactId>traceguard</artifactId>
    <version>1.0.0</version>
    <name>TraceGuard</name>
    <description>Route trace, release impact and end-to-end log/Splunk verification for Apache Camel XML DSL frameworks</description>

    <properties>
        <java.version>21</java.version>
        <camel.version>4.18.0</camel.version>
        <javaparser.version>3.26.2</javaparser.version>
        <jgit.version>6.10.0.202406032230-r</jgit.version>
        <exec.plugin.version>3.5.0</exec.plugin.version>
        <frontend.dir>${project.basedir}/src/main/frontend</frontend.dir>
        <!-- The React build uses the system npm on PATH (node is a prerequisite).
             Defaults are for *nix; the 'windows' profile below runs via cmd /c. -->
        <npm.executable>npm</npm.executable>
        <npm.install.args>install</npm.install.args>
        <npm.build.args>run build</npm.build.args>
        <!-- -Dskip.frontend=true skips the React build (fast Java-only iterations). -->
        <skip.frontend>false</skip.frontend>

        <!-- 'dist' profile (mvn -Pdist package): jlink a trimmed JRE into a self-contained,
             zero-install desktop bundle. Curated module set — verified to boot Spring Boot +
             Tomcat + Camel + JGit(TLS). Defaults are for *nix; the OS profiles below override
             jlink.executable / os.tag. -->
        <jlink.executable>${java.home}/bin/jlink</jlink.executable>
        <jpackage.executable>${java.home}/bin/jpackage</jpackage.executable>
        <exe.suffix></exe.suffix>
        <os.tag>unix</os.tag>
        <jlink.modules>java.base,java.desktop,java.instrument,java.logging,java.management,java.naming,java.net.http,java.prefs,java.rmi,java.scripting,java.security.jgss,java.security.sasl,java.sql,java.transaction.xa,java.xml,jdk.crypto.ec,jdk.crypto.cryptoki,jdk.unsupported,jdk.zipfs,jdk.jdwp.agent</jlink.modules>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>org.apache.camel</groupId>
                <artifactId>camel-bom</artifactId>
                <version>${camel.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

        <!-- Camel 4 core: RouteDefinition / ProcessorDefinition model -->
        <dependency>
            <groupId>org.apache.camel</groupId>
            <artifactId>camel-core</artifactId>
        </dependency>
        <!-- Camel 4 XML IO DSL: loads <routes>/<route> XML into RouteDefinitions -->
        <dependency>
            <groupId>org.apache.camel</groupId>
            <artifactId>camel-xml-io-dsl</artifactId>
        </dependency>

        <!-- Parse controller sources to resolve operation names -->
        <dependency>
            <groupId>com.github.javaparser</groupId>
            <artifactId>javaparser-core</artifactId>
            <version>${javaparser.version}</version>
        </dependency>

        <!-- Pure-Java git: clone/fetch a Bitbucket branch as a source (no git binary needed) -->
        <dependency>
            <groupId>org.eclipse.jgit</groupId>
            <artifactId>org.eclipse.jgit</artifactId>
            <version>${jgit.version}</version>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>

            <!-- Build the React + Vite + TS app using the system npm on PATH (no download). -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>${exec.plugin.version}</version>
                <executions>
                    <execution>
                        <id>npm-install</id>
                        <phase>generate-resources</phase>
                        <goals><goal>exec</goal></goals>
                        <configuration>
                            <executable>${npm.executable}</executable>
                            <workingDirectory>${frontend.dir}</workingDirectory>
                            <commandlineArgs>${npm.install.args}</commandlineArgs>
                            <skip>${skip.frontend}</skip>
                        </configuration>
                    </execution>
                    <execution>
                        <id>npm-build</id>
                        <phase>generate-resources</phase>
                        <goals><goal>exec</goal></goals>
                        <configuration>
                            <executable>${npm.executable}</executable>
                            <workingDirectory>${frontend.dir}</workingDirectory>
                            <commandlineArgs>${npm.build.args}</commandlineArgs>
                            <skip>${skip.frontend}</skip>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Wipe the previously-copied frontend bundle BEFORE re-copying, so stale
                 content-hashed assets (index-<hash>.js/.css) from earlier builds don't
                 accumulate in the served static dir. Runs in process-classes ahead of the
                 copy below (same phase → POM order). excludeDefaultDirectories=true is
                 essential: it limits cleaning to the explicit fileset and never touches
                 target/ (the freshly compiled classes). Skipped with -Dskip.frontend=true
                 so Java-only iterations keep the existing UI. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-clean-plugin</artifactId>
                <executions>
                    <execution>
                        <id>clean-stale-frontend</id>
                        <phase>process-classes</phase>
                        <goals><goal>clean</goal></goals>
                        <configuration>
                            <skip>${skip.frontend}</skip>
                            <excludeDefaultDirectories>true</excludeDefaultDirectories>
                            <filesets>
                                <fileset>
                                    <directory>${project.build.outputDirectory}/static</directory>
                                </fileset>
                            </filesets>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Copy the Vite build output into the served static resources. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <executions>
                    <execution>
                        <id>copy-frontend</id>
                        <phase>process-classes</phase>
                        <goals><goal>copy-resources</goal></goals>
                        <configuration>
                            <outputDirectory>${project.build.outputDirectory}/static</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>${frontend.dir}/dist</directory>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!-- On Windows, run npm through cmd /c so the npm.cmd launcher resolves
             reliably from PATH (direct exec of npm.cmd is flaky under spring-boot:run). -->
        <profile>
            <id>windows</id>
            <activation>
                <os><family>windows</family></os>
            </activation>
            <properties>
                <npm.executable>cmd</npm.executable>
                <npm.install.args>/c npm install</npm.install.args>
                <npm.build.args>/c npm run build</npm.build.args>
                <jlink.executable>${java.home}/bin/jlink.exe</jlink.executable>
                <jpackage.executable>${java.home}/bin/jpackage.exe</jpackage.executable>
                <exe.suffix>.exe</exe.suffix>
                <os.tag>windows</os.tag>
            </properties>
        </profile>
        <profile>
            <id>mac</id>
            <activation><os><family>mac</family></os></activation>
            <properties><os.tag>mac</os.tag></properties>
        </profile>
        <profile>
            <id>linux</id>
            <activation>
                <os><family>unix</family><name>linux</name></os>
            </activation>
            <properties><os.tag>linux</os.tag></properties>
        </profile>

        <!-- ============================================================================
             mvn -Pdist package   ->   a self-contained, zero-install desktop bundle.
             Builds the fat jar (as usual), jlinks a trimmed JRE, drops in the launcher
             + icon, and zips it all. No PowerShell / .bat script execution needed — pure
             Maven, so it works where group policy blocks scripts. Output:
                 target/dist/TraceGuard-<os>/       (the folder)
                 target/dist/TraceGuard-<os>.zip    (ship this)
             jlink builds a runtime for the OS Maven runs on, so build the mac bundle on a
             Mac, the windows bundle on Windows. Normal `package` / spring-boot:run are
             unaffected (this only runs under -Pdist).
             ============================================================================ -->
        <profile>
            <id>dist</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-antrun-plugin</artifactId>
                        <version>3.1.0</version>
                        <executions>
                            <execution>
                                <id>bundle</id>
                                <phase>package</phase>
                                <goals><goal>run</goal></goals>
                                <configuration>
                                    <target>
                                        <property name="bundle" value="${project.build.directory}/dist/TraceGuard-${os.tag}"/>
                                        <delete dir="${project.build.directory}/dist"/>
                                        <mkdir dir="${bundle}/app"/>
                                        <echo message="jlink -> trimmed JRE (${os.tag}) using ${jlink.executable}"/>
                                        <!-- compress=zip-0 (uncompressed): larger on disk but classes load as fast as a
                                             full JDK - compression makes analysis slower (a Camel context per XML file
                                             loads many classes). -->
                                        <exec executable="${jlink.executable}" failonerror="true">
                                            <arg line="--add-modules ${jlink.modules} --strip-debug --no-header-files --no-man-pages --compress=zip-0 --output &quot;${bundle}/jre&quot;"/>
                                        </exec>
                                        <!-- Generate the default CDS archive so JDK classes load as fast as on a full
                                             JDK (a jlink image ships without one). Non-fatal if it can't be created. -->
                                        <echo message="generating CDS archive (faster class loading)"/>
                                        <exec executable="${bundle}/jre/bin/java${exe.suffix}" failonerror="false">
                                            <arg value="-Xshare:dump"/>
                                        </exec>
                                        <copy file="${project.build.directory}/${project.build.finalName}.jar"
                                              tofile="${bundle}/app/traceguard.jar"/>
                                        <copy todir="${bundle}">
                                            <fileset dir="${project.basedir}/packaging/launcher"/>
                                            <fileset dir="${project.basedir}/packaging" includes="traceguard.ico"/>
                                        </copy>
                                        <zip destfile="${project.build.directory}/dist/TraceGuard-${os.tag}.zip">
                                            <!-- filemode 755 keeps the .command launcher + jre binaries executable on macOS/Linux -->
                                            <zipfileset dir="${bundle}" prefix="TraceGuard-${os.tag}" filemode="755"/>
                                        </zip>
                                        <echo message="=================================================================="/>
                                        <echo message="  Bundle : ${bundle}"/>
                                        <echo message="  Zip    : ${project.build.directory}/dist/TraceGuard-${os.tag}.zip  (share this)"/>
                                        <echo message="  Run    : unzip, then double-click TraceGuard.bat (Windows) / TraceGuard.command (macOS)"/>
                                        <echo message="=================================================================="/>
                                    </target>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!-- ============================================================================
             mvn -Pexe package   ->   a native TraceGuard.exe (Windows) via jpackage.
             Produces an "app-image": a folder with TraceGuard.exe + an embedded runtime,
             carrying the shield icon. No admin, no installer, no MSI/WiX — unzip-and-run,
             just like the .bat bundle but a real .exe. The launcher bakes in
             -Dtracer.open-browser=true, so double-clicking the .exe starts the server and
             opens the browser itself. Output:
                 target/dist-exe/TraceGuard/TraceGuard.exe   (+ runtime/, app/)
                 target/dist-exe/TraceGuard-windows-exe.zip  (ship this)
             Windows-only (uses the win-console launcher); run it on Windows. jpackage ships
             with the JDK, so there is nothing extra to install.
             ============================================================================ -->
        <profile>
            <id>exe</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-antrun-plugin</artifactId>
                        <version>3.1.0</version>
                        <executions>
                            <execution>
                                <id>jpackage-exe</id>
                                <phase>package</phase>
                                <goals><goal>run</goal></goals>
                                <configuration>
                                    <target>
                                        <property name="stage" value="${project.build.directory}/jpackage-input"/>
                                        <property name="out" value="${project.build.directory}/dist-exe"/>
                                        <delete dir="${stage}"/>
                                        <delete dir="${out}"/>
                                        <mkdir dir="${stage}"/>
                                        <!-- jpackage bundles everything in the input dir into the app; stage only the jar -->
                                        <copy file="${project.build.directory}/${project.build.finalName}.jar"
                                              tofile="${stage}/traceguard.jar"/>
                                        <echo message="jpackage -> native TraceGuard.exe using ${jpackage.executable}"/>
                                        <exec executable="${jpackage.executable}" failonerror="true">
                                            <arg value="--type"/>            <arg value="app-image"/>
                                            <arg value="--name"/>            <arg value="TraceGuard"/>
                                            <arg value="--input"/>           <arg value="${stage}"/>
                                            <arg value="--main-jar"/>        <arg value="traceguard.jar"/>
                                            <arg value="--icon"/>            <arg value="${project.basedir}/packaging/traceguard.ico"/>
                                            <arg value="--java-options"/>    <arg value="-Dtracer.open-browser=true"/>
                                            <arg value="--add-modules"/>     <arg value="${jlink.modules}"/>
                                            <arg value="--app-version"/>     <arg value="${project.version}"/>
                                            <arg value="--vendor"/>          <arg value="UOB"/>
                                            <arg value="--win-console"/>
                                            <arg value="--dest"/>            <arg value="${out}"/>
                                        </exec>
                                        <!-- the exe icon comes from the icon arg above; also drop the .ico alongside -->
                                        <copy file="${project.basedir}/packaging/traceguard.ico" todir="${out}/TraceGuard"/>
                                        <zip destfile="${out}/TraceGuard-windows-exe.zip">
                                            <zipfileset dir="${out}/TraceGuard" prefix="TraceGuard" filemode="755"/>
                                        </zip>
                                        <echo message="=================================================================="/>
                                        <echo message="  Exe : ${out}/TraceGuard/TraceGuard.exe"/>
                                        <echo message="  Zip : ${out}/TraceGuard-windows-exe.zip  (share this)"/>
                                        <echo message="  Run : unzip, then double-click TraceGuard.exe"/>
                                        <echo message="=================================================================="/>
                                    </target>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
